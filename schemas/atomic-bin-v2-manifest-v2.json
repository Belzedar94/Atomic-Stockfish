{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atomic-stockfish.example/schemas/atomic-bin-v2-manifest-v2.json",
  "title": "Atomic BIN V2 authenticated teacher manifest V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "manifest_schema_sha256", "data_schema_sha256", "format", "engine", "network", "book", "generation", "statistics", "shards"],
  "properties": {
    "manifest_version": {"const": 2},
    "manifest_schema_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "data_schema_sha256": {"const": "0352b036f2a140c609e3eb9c9d635dc553e8d77253d8faa92437390f5cf93cb6"},
    "format": {"const": "atomic-bin-v2"},
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "version"],
      "properties": {
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "version": {"type": "string", "minLength": 1},
        "producer_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "sha256"],
      "properties": {
        "file": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "book": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "file", "sha256"],
      "properties": {
        "kind": {"enum": ["file", "builtin-startpos"]},
        "file": {"type": ["string", "null"]},
        "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolved_seed", "atomic960", "threads", "hash_mb", "teacher_mode", "use_nnue", "options", "syzygy"],
      "properties": {
        "resolved_seed": {"type": "string", "pattern": "^(0|[1-9][0-9]{0,19})$"},
        "atomic960": {"const": false},
        "threads": {"type": "integer", "minimum": 1, "maximum": 4294967295},
        "hash_mb": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
        "teacher_mode": {"enum": ["pure", "true"]},
        "use_nnue": {"enum": ["pure", "true"]},
        "options": {"$ref": "atomic-bin-v2-manifest.json#/properties/generation/properties/options"},
        "syzygy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inventory_sha256", "cardinality", "probe_limit", "probe_depth", "rule50", "wdl_suffix", "dtz_suffix"],
          "properties": {
            "inventory_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "cardinality": {"const": 6},
            "probe_limit": {"const": 6},
            "probe_depth": {"const": 1},
            "rule50": {"const": true},
            "wdl_suffix": {"const": ".atbw"},
            "dtz_suffix": {"const": ".atbz"}
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"teacher_mode": {"const": "pure"}}},
          "then": {"properties": {"use_nnue": {"const": "pure"}}},
          "else": {"properties": {"use_nnue": {"const": "true"}}}
        }
      ]
    },
    "statistics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["records", "draws", "tb_probes", "tb_hits"],
      "properties": {
        "records": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
        "draws": {"type": "string", "pattern": "^(0|[1-9][0-9]{0,19})$"},
        "tb_probes": {"type": "string", "pattern": "^(0|[1-9][0-9]{0,19})$"},
        "tb_hits": {"type": "string", "pattern": "^(0|[1-9][0-9]{0,19})$"}
      }
    },
    "shards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "file", "records", "bytes", "sha256"],
        "properties": {
          "index": {"const": 0},
          "file": {"type": "string", "minLength": 1},
          "records": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
          "bytes": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
