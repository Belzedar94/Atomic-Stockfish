{
  "name": "@atomic-stockfish/ffish",
  "version": "1.0.0",
  "description": "Atomic-only rules API for JavaScript and WebAssembly",
  "homepage": "https://github.com/Belzedar94/Atomic-Stockfish",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Belzedar94/Atomic-Stockfish.git"
  },
  "bugs": {
    "url": "https://github.com/Belzedar94/Atomic-Stockfish/issues"
  },
  "type": "commonjs",
  "main": "dist/cjs/ffish.js",
  "module": "dist/esm/ffish.mjs",
  "types": "ffish.d.ts",
  "exports": {
    ".": {
      "types": "./ffish.d.ts",
      "require": "./dist/cjs/ffish.js",
      "import": "./dist/esm/ffish.mjs"
    }
  },
  "files": [
    "AUTHORS",
    "CITATION.cff",
    "LICENSE",
    "README.md",
    "dist/cjs/ffish.js",
    "dist/cjs/ffish.wasm",
    "dist/esm/ffish.mjs",
    "dist/esm/ffish.wasm",
    "ffish.d.ts"
  ],
  "scripts": {
    "build": "docker compose run --rm emscripten make -f Makefile_js all",
    "build:debug": "docker compose run --rm emscripten make -f Makefile_js all DEBUG=yes",
    "test": "node test-commonjs.cjs && node test-esm.mjs",
    "test:cjs": "node test-commonjs.cjs",
    "test:esm": "node test-esm.mjs",
    "repro": "docker compose run --rm emscripten make -f Makefile_js repro"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "GPL-3.0-or-later"
}
