{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Belzedar94/Atomic-Stockfish/schemas/atomic-v3-dataset-stats-v1.json",
  "title": "AtomicNNUEV3 authenticated single-partition dataset statistics",
  "description": "One sidecar describes exactly one train or validation atomic-bin-v2 manifest. Counts are canonical uint64 decimal strings, ratios are derived from integer numerators and denominators, and WHITE/BLACK coverage is never aggregated.",
  "x-semantic-invariants": [
    "the training-run manifest hashes this sidecar and every artifact named by it",
    "manifest, ledger, index coverage and policy file bytes and hashes are verified before scanning",
    "manifest role, record count and data schema match the ledger header and this sidecar",
    "both role sidecars repeat the exact precommitted partition config and generation provenance from the one authenticated policy",
    "backend reachability_mask_sha256 and all twelve per-perspective physical/HM-derived structural mask hashes equal the authenticated policy and trailing index-coverage bitmaps",
    "every record belongs to exactly one contiguous ledger range and one label-free split group",
    "all ledger split groups recompute to this sidecar role under the authenticated seed and threshold",
    "scan.all_ledger_entries_structurally_scanned proves fixed-width ledger parsing, range continuity and hash recomputation only; legal Atomic replay is a separate engine-backed publication gate",
    "scan.records_scanned equals manifest and ledger record counts and scan.perspectives_scanned equals twice that value",
    "authenticated histogram boundaries for ply and rule50 are nonnegative and piece_count boundaries are in the inclusive range 0 through 32",
    "each histogram count sum, WDL sum and shared network-bucket sum equals scan.records_scanned",
    "sum(WHITE.hm_king_buckets) equals sum(BLACK.hm_king_buckets) equals sum(distribution.network_buckets) equals scan.records_scanned; the 32-entry king-square histograms are not elementwise equal to the shared 8-entry material-bucket histogram",
    "for each perspective the HM mirror-branch sum equals scan.records_scanned",
    "for evaluable nonterminal positions with both kings and at most 32 pieces, per-slice active maxima are bounded by HM 32, CapturePair 240, KingBlastEP 35 and BlastRing 240; a king-absent terminal is resolved before NNUE enumeration",
    "for each perspective scan.max_active_observed is the observed maximum of the per-record sum across all four slices, is at least every per-slice observed maximum, is at most their sum, and never exceeds the conservative independent-slice sum 547",
    "for each slice structurally_reachable + structurally_unreachable equals physical_dimensions",
    "for each slice observed_reachable + reachable_unobserved equals structurally_reachable",
    "for each slice structural counts equal bitmap popcount, observed counts equal reachable indices with nonzero counters, and every nonzero counter under a zero structural bit is rejected",
    "all per-index counters, class matrices and semantic counters agree with an independent full-refresh oracle",
    "under a release-candidate policy trajectory_events.stop_reasons indices 7 and 8 are zero because the v1 ledger cannot prove score-draw adjudication or evaluation resignation",
    "validation coverage is evaluated independently against the authenticated coverage policy",
    "no invalid record, truncated active list, accumulator overflow or strict-EOF failure is accepted"
  ],
  "x-active-count-contract": {
    "source": "schemas/atomic-nnue-v3.json#active_feature_bounds",
    "scope": "evaluable nonterminal positions with both kings, no more than 16 pieces per color and no more than 32 board pieces; king-absent terminals bypass NNUE",
    "activation_domain": "physical/runtime-export",
    "factorized_training_note": "the 547 scanner/runtime bound excludes HM virtual rows because export coalesces them; factorized training activates at most 579 parameter rows (547 + 32 HM virtual)",
    "slice_maxima": {
      "half_ka_v2_atomic_hm": 32,
      "atomic_capture_pair": 240,
      "atomic_king_blast_ep": 35,
      "atomic_blast_ring": 240
    },
    "aggregate_classification": "conservative-independent-slice-sum",
    "aggregate_formula": "32 + 240 + 35 + 240",
    "aggregate_maximum": 547,
    "accumulator_capacity": 1024,
    "capacity_headroom": 477,
    "scan_field": "scan.max_active_observed.{WHITE,BLACK}",
    "linkage": "for each perspective, scan.max_active_observed is max_per_record(sum(active slice counts)); it is greater than or equal to each slice active_per_position.maximum and less than or equal to their sum"
  },
  "x-stop-reason-release-contract": {
    "wire_mapping_preserved": "indices 0 through 8 remain stable for pilot and backward inspection",
    "release_candidate_required_zero_indices": [
      7,
      8
    ],
    "generator_requirement": "adjudicate_draws_by_score=false and adjudicate_resignations=false"
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "role",
    "provenance",
    "artifacts",
    "backend",
    "scanner",
    "scan",
    "split",
    "distribution",
    "coverage_by_perspective",
    "record_events",
    "trajectory_events",
    "deduplication"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "role": {
      "enum": [
        "train",
        "validation"
      ]
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "backend": {
      "$ref": "#/$defs/backend"
    },
    "scanner": {
      "$ref": "#/$defs/scanner"
    },
    "scan": {
      "$ref": "#/$defs/scan"
    },
    "split": {
      "$ref": "#/$defs/split"
    },
    "distribution": {
      "$ref": "#/$defs/distribution"
    },
    "coverage_by_perspective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "WHITE",
        "BLACK"
      ],
      "properties": {
        "WHITE": {
          "$ref": "#/$defs/perspectiveCoverage"
        },
        "BLACK": {
          "$ref": "#/$defs/perspectiveCoverage"
        }
      }
    },
    "record_events": {
      "$ref": "#/$defs/recordEvents"
    },
    "trajectory_events": {
      "$ref": "#/$defs/trajectoryEvents"
    },
    "deduplication": {
      "$ref": "#/$defs/deduplication"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "uint64": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]{0,19})$",
      "x-decimal-maximum": "18446744073709551615"
    },
    "count": {
      "$ref": "#/$defs/uint64"
    },
    "smallCount": {
      "type": "integer",
      "minimum": 0
    },
    "basename": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.{1,2}$)[^/\\\\:\\u0000<>\\\"|?*]+$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file",
        "bytes",
        "sha256",
        "schema_sha256"
      ],
      "properties": {
        "file": {
          "$ref": "#/$defs/basename"
        },
        "bytes": {
          "$ref": "#/$defs/uint64"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "schema_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "artifacts": {
